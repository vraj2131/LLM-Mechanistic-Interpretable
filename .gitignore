# Data — never commit raw or cached data
data/raw/
data/caches/
data/interim/
data/processed/

# Allow lightweight result files needed by the dashboard
!data/processed/scifact/probe_results.json
!data/processed/nfcorpus/probe_results.json

# Large binary outputs
outputs/final/sae_checkpoints/
outputs/final/sae_activations/
outputs/final/probe_weights/
*.npy
*.pkl

# Allow small dashboard outputs
!outputs/final/retrieval_metrics.json
!outputs/final/figures/
!outputs/final/interventions/
!outputs/final/sae_analysis/**/*.parquet

# HuggingFace model cache
~/.cache/huggingface/
.cache/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Secrets
.env
*.env
.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
